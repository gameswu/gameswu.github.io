---
/**
 * MusicBox —— 音乐盒 + 觉立绘
 *
 * 功能：
 *   - 自动扫描 public/music/ 下的音频文件（.mp3/.ogg/.m4a/.flac/.wav）
 *     曲名即文件名（去扩展名）
 *   - 默认不播放；左下角立绘头发露出一小块（折叠态音乐盒图标）
 *   - 点开面板 → 播放/暂停 / 上一首 / 下一首 / 切换立绘显示
 *   - 播放中离开本标签 → 标签栏显示 "♫ 曲名"
 *   - 跨页续播：sessionStorage 保存 {曲目 index, 进度, 是否播放}
 *   - Media Session API：系统级媒体控制
 *   - 立绘按播放状态切换表情组（idle/playing/paused），同组内 40–50s 随机切图
 *
 * 若 tracks 为空 → 整个组件不渲染
 * 若 sprites 为 null（无 idle 立绘）→ 只渲染纯音乐盒图标，无立绘
 */
import { getMusicBoxConfig } from '@/config/music';

const { tracks, sprites } = getMusicBoxConfig();
const hasTracks = tracks.length > 0;
---

{
  hasTracks && (
    <div
      class="music-box-root"
      data-tracks={JSON.stringify(tracks)}
      data-sprites={sprites ? JSON.stringify(sprites) : ''}
    >
      {sprites && (
        <div class="music-box-character" data-state="idle" aria-hidden="true">
          <img class="music-box-character-img" src={sprites.idle[0]} alt="" />
        </div>
      )}

      <button
        class="music-box-toggle"
        type="button"
        aria-label="音乐盒"
        aria-expanded="false"
      >
        <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true">
          <path d="M12 3v10.55a4 4 0 1 0 2 3.45V7h4V3h-6z" />
        </svg>
      </button>

      <div class="music-box-panel" hidden>
        <div class="music-box-meta">
          <div class="music-box-title" data-field="title">—</div>
        </div>

        <div class="music-box-progress">
          <span class="music-box-time" data-field="current">0:00</span>
          <input
            type="range"
            class="music-box-seek"
            data-action="seek"
            min="0"
            max="1000"
            value="0"
            step="1"
            aria-label="播放进度"
          />
          <span class="music-box-time" data-field="duration">0:00</span>
        </div>

        <div class="music-box-controls">
          <button type="button" data-action="prev" aria-label="上一首">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M6 6h2v12H6zM9.5 12l8.5 6V6z"/></svg>
          </button>
          <button type="button" data-action="play" aria-label="播放">
            <svg class="icon-play" viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            <svg class="icon-pause" viewBox="0 0 24 24" width="22" height="22" fill="currentColor" hidden><path d="M6 5h4v14H6zM14 5h4v14h-4z"/></svg>
          </button>
          <button type="button" data-action="next" aria-label="下一首">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M16 6h2v12h-2zM6 18l8.5-6L6 6z"/></svg>
          </button>

          <div class="music-box-volume">
            <button type="button" data-action="mute" aria-label="静音" class="music-box-volume-btn">
              <svg class="icon-volume" viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3a4.5 4.5 0 0 0-2.5-4v8a4.5 4.5 0 0 0 2.5-4z"/></svg>
              <svg class="icon-muted" viewBox="0 0 24 24" width="18" height="18" fill="currentColor" hidden><path d="M16.5 12A4.5 4.5 0 0 0 14 8v2.18L16.45 12.63a4.5 4.5 0 0 0 .05-.63zM19 12c0 .94-.2 1.82-.54 2.64l1.51 1.51A8.98 8.98 0 0 0 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06a8.99 8.99 0 0 0 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/></svg>
            </button>
            <input
              type="range"
              class="music-box-volume-slider"
              data-action="volume"
              min="0"
              max="100"
              value="80"
              step="1"
              aria-label="音量"
            />
          </div>
        </div>

        {sprites && (
          <label class="music-box-char-toggle">
            <input type="checkbox" data-action="toggle-char" checked />
            <span>显示立绘</span>
          </label>
        )}
      </div>

      <audio data-audio preload="metadata" />
    </div>
  )
}

<script>
  (() => {
    if (typeof window === 'undefined') return;
    const root = document.querySelector<HTMLDivElement>('.music-box-root');
    if (!root) return;

    interface Track { src: string; title: string; }
    interface Sprites { idle: string[]; playing: string[]; paused: string[]; }

    const tracks: Track[] = JSON.parse(root.dataset.tracks || '[]');
    if (tracks.length === 0) return;
    const spritesRaw = root.dataset.sprites;
    const sprites: Sprites | null = spritesRaw ? JSON.parse(spritesRaw) : null;

    const audio = root.querySelector<HTMLAudioElement>('[data-audio]')!;
    const toggleBtn = root.querySelector<HTMLButtonElement>('.music-box-toggle')!;
    const panel = root.querySelector<HTMLDivElement>('.music-box-panel')!;
    const titleEl = root.querySelector<HTMLDivElement>('[data-field="title"]')!;
    const playBtn = root.querySelector<HTMLButtonElement>('[data-action="play"]')!;
    const prevBtn = root.querySelector<HTMLButtonElement>('[data-action="prev"]')!;
    const nextBtn = root.querySelector<HTMLButtonElement>('[data-action="next"]')!;
    const iconPlay = playBtn.querySelector<SVGElement>('.icon-play')!;
    const iconPause = playBtn.querySelector<SVGElement>('.icon-pause')!;
    const charToggleInput = root.querySelector<HTMLInputElement>('[data-action="toggle-char"]');
    const charEl = root.querySelector<HTMLDivElement>('.music-box-character');
    const charImgEl = root.querySelector<HTMLImageElement>('.music-box-character-img');

    const seekEl = root.querySelector<HTMLInputElement>('[data-action="seek"]')!;
    const currentTimeEl = root.querySelector<HTMLSpanElement>('[data-field="current"]')!;
    const durationEl = root.querySelector<HTMLSpanElement>('[data-field="duration"]')!;
    const volumeEl = root.querySelector<HTMLInputElement>('[data-action="volume"]')!;
    const muteBtn = root.querySelector<HTMLButtonElement>('[data-action="mute"]')!;
    const iconVolume = muteBtn.querySelector<SVGElement>('.icon-volume')!;
    const iconMuted = muteBtn.querySelector<SVGElement>('.icon-muted')!;

    // ---- 持久化键 ----
    const SS_STATE = 'musicbox.state';      // session：index / time / wasPlaying
    const SS_INTERACTED = 'musicbox.interacted'; // session：用户曾主动播放过
    const LS_PANEL_OPEN = 'musicbox.panelOpen';  // local：面板是否展开
    const LS_CHAR_VISIBLE = 'musicbox.charVisible'; // local：立绘是否显示
    const LS_VOLUME = 'musicbox.volume';             // local：音量 0–1
    const LS_MUTED = 'musicbox.muted';               // local：是否静音

    // ---- 运行时状态 ----
    let currentIdx = 0;
    let state: 'idle' | 'playing' | 'paused' = 'idle';
    let originalTitle = document.title;
    let spriteTimer: number | null = null;

    // ---- 面板展开/折叠持久化 ----
    function setPanelOpen(open: boolean) {
      panel.hidden = !open;
      toggleBtn.setAttribute('aria-expanded', String(open));
      root.classList.toggle('is-open', open);
      try { localStorage.setItem(LS_PANEL_OPEN, open ? '1' : '0'); } catch {}
    }
    toggleBtn.addEventListener('click', () => setPanelOpen(panel.hidden));
    try {
      if (localStorage.getItem(LS_PANEL_OPEN) === '1') setPanelOpen(true);
    } catch {}

    // ---- 立绘显示开关 ----
    function applyCharVisible(visible: boolean) {
      if (!charEl) return;
      charEl.hidden = !visible;
      root.classList.toggle('char-hidden', !visible);
    }
    if (charToggleInput && charEl) {
      let initial = true;
      try {
        const stored = localStorage.getItem(LS_CHAR_VISIBLE);
        if (stored === '0') initial = false;
      } catch {}
      charToggleInput.checked = initial;
      applyCharVisible(initial);
      charToggleInput.addEventListener('change', () => {
        applyCharVisible(charToggleInput.checked);
        try { localStorage.setItem(LS_CHAR_VISIBLE, charToggleInput.checked ? '1' : '0'); } catch {}
      });
    }

    // ---- 进度条 ----
    function formatTime(s: number): string {
      if (!Number.isFinite(s) || s < 0) return '0:00';
      const m = Math.floor(s / 60);
      const sec = Math.floor(s % 60);
      return `${m}:${sec.toString().padStart(2, '0')}`;
    }
    let seeking = false;
    function renderProgress() {
      if (seeking) return;
      const dur = audio.duration;
      const cur = audio.currentTime;
      currentTimeEl.textContent = formatTime(cur);
      if (Number.isFinite(dur) && dur > 0) {
        durationEl.textContent = formatTime(dur);
        seekEl.value = String(Math.round((cur / dur) * 1000));
      } else {
        durationEl.textContent = '0:00';
        seekEl.value = '0';
      }
    }
    audio.addEventListener('loadedmetadata', renderProgress);
    audio.addEventListener('durationchange', renderProgress);
    seekEl.addEventListener('input', () => {
      seeking = true;
      const dur = audio.duration;
      if (Number.isFinite(dur) && dur > 0) {
        currentTimeEl.textContent = formatTime((Number(seekEl.value) / 1000) * dur);
      }
    });
    seekEl.addEventListener('change', () => {
      const dur = audio.duration;
      if (Number.isFinite(dur) && dur > 0) {
        audio.currentTime = (Number(seekEl.value) / 1000) * dur;
      }
      seeking = false;
    });

    // ---- 音量 / 静音 ----
    function renderMuteIcon() {
      const muted = audio.muted || audio.volume === 0;
      iconVolume.hidden = muted;
      iconMuted.hidden = !muted;
      muteBtn.setAttribute('aria-label', muted ? '取消静音' : '静音');
    }
    function applyVolume(v: number, persist = true) {
      const clamped = Math.max(0, Math.min(1, v));
      audio.volume = clamped;
      volumeEl.value = String(Math.round(clamped * 100));
      if (persist) { try { localStorage.setItem(LS_VOLUME, String(clamped)); } catch {} }
      renderMuteIcon();
    }
    // 初始化音量
    let initVol = 0.8;
    try {
      const v = Number(localStorage.getItem(LS_VOLUME));
      if (Number.isFinite(v) && v >= 0 && v <= 1) initVol = v;
    } catch {}
    let initMuted = false;
    try { initMuted = localStorage.getItem(LS_MUTED) === '1'; } catch {}
    audio.muted = initMuted;
    applyVolume(initVol, false);

    volumeEl.addEventListener('input', () => {
      const v = Number(volumeEl.value) / 100;
      if (audio.muted && v > 0) audio.muted = false;
      applyVolume(v);
      try { localStorage.setItem(LS_MUTED, audio.muted ? '1' : '0'); } catch {}
    });
    muteBtn.addEventListener('click', () => {
      audio.muted = !audio.muted;
      try { localStorage.setItem(LS_MUTED, audio.muted ? '1' : '0'); } catch {}
      renderMuteIcon();
    });
    audio.addEventListener('volumechange', renderMuteIcon);

    // ---- 立绘表情切换 ----
    function pickSpriteFrame(list: string[]): string {
      return list[Math.floor(Math.random() * list.length)];
    }
    function applySpriteState(next: 'idle' | 'playing' | 'paused') {
      if (!sprites || !charEl || !charImgEl) return;
      charEl.dataset.state = next;
      const list = sprites[next] ?? sprites.idle;
      charImgEl.src = pickSpriteFrame(list);
      // 重置定时器
      if (spriteTimer != null) { clearTimeout(spriteTimer); spriteTimer = null; }
      scheduleSpriteSwap();
    }
    function scheduleSpriteSwap() {
      if (!sprites || !charImgEl) return;
      const delay = 40000 + Math.random() * 10000; // 40–50s
      spriteTimer = window.setTimeout(() => {
        const list = sprites[state] ?? sprites.idle;
        if (list.length > 1) charImgEl.src = pickSpriteFrame(list);
        scheduleSpriteSwap();
      }, delay);
    }

    // ---- 标签栏显示 ----
    function updateTabTitle() {
      if (state === 'playing' && document.hidden) {
        document.title = `♫ ${tracks[currentIdx].title}`;
      } else {
        document.title = originalTitle;
      }
    }
    document.addEventListener('visibilitychange', updateTabTitle);
    // 防御：其他脚本可能改 title（SPA nav 之类），这里只在需要时覆盖
    window.addEventListener('pagehide', () => { document.title = originalTitle; });

    // ---- Media Session API ----
    function updateMediaSession() {
      if (!('mediaSession' in navigator)) return;
      const t = tracks[currentIdx];
      navigator.mediaSession.metadata = new MediaMetadata({ title: t.title });
      navigator.mediaSession.playbackState = state === 'playing' ? 'playing' : state === 'paused' ? 'paused' : 'none';
    }
    if ('mediaSession' in navigator) {
      navigator.mediaSession.setActionHandler('play', () => play());
      navigator.mediaSession.setActionHandler('pause', () => pause());
      navigator.mediaSession.setActionHandler('previoustrack', () => prev());
      navigator.mediaSession.setActionHandler('nexttrack', () => next());
    }

    // ---- UI 同步 ----
    function renderMeta() {
      titleEl.textContent = tracks[currentIdx].title;
    }
    function renderPlayIcon() {
      const isPlaying = state === 'playing';
      iconPlay.hidden = isPlaying;
      iconPause.hidden = !isPlaying;
      playBtn.setAttribute('aria-label', isPlaying ? '暂停' : '播放');
      root.classList.toggle('is-playing', isPlaying);
    }

    // ---- 状态变更入口 ----
    function setState(next: 'idle' | 'playing' | 'paused') {
      state = next;
      renderPlayIcon();
      applySpriteState(next);
      updateTabTitle();
      updateMediaSession();
      persist();
    }

    function loadTrack(idx: number, autoplay: boolean, seekTo = 0) {
      currentIdx = ((idx % tracks.length) + tracks.length) % tracks.length;
      audio.src = tracks[currentIdx].src;
      renderMeta();
      if (seekTo > 0) {
        audio.addEventListener('loadedmetadata', () => { audio.currentTime = seekTo; }, { once: true });
      }
      if (autoplay) {
        audio.play().then(() => setState('playing')).catch(() => setState('paused'));
      } else {
        setState(seekTo > 0 ? 'paused' : 'idle');
      }
    }

    function play() {
      try { sessionStorage.setItem(SS_INTERACTED, '1'); } catch {}
      audio.play().then(() => setState('playing')).catch(() => setState('paused'));
    }
    function pause() { audio.pause(); setState('paused'); }
    function prev() { loadTrack(currentIdx - 1, state === 'playing'); }
    function next() { loadTrack(currentIdx + 1, state === 'playing'); }

    playBtn.addEventListener('click', () => {
      if (state === 'playing') pause(); else play();
    });
    prevBtn.addEventListener('click', prev);
    nextBtn.addEventListener('click', next);

    // 自然结束 → 下一首自动续播（保持 playing 状态）
    audio.addEventListener('ended', () => { loadTrack(currentIdx + 1, true); });
    audio.addEventListener('play', () => { if (state !== 'playing') setState('playing'); });
    audio.addEventListener('pause', () => { if (state === 'playing') setState('paused'); });

    // ---- 持久化（进度）----
    function persist() {
      try {
        sessionStorage.setItem(SS_STATE, JSON.stringify({
          idx: currentIdx,
          time: audio.currentTime || 0,
          wasPlaying: state === 'playing',
        }));
      } catch {}
    }
    // 进度每 2s 持久化一次，避免频繁写
    let lastPersist = 0;
    audio.addEventListener('timeupdate', () => {
      renderProgress();
      const now = performance.now();
      if (now - lastPersist > 2000) { lastPersist = now; persist(); }
    });
    window.addEventListener('beforeunload', persist);

    // ---- 初始化：尝试恢复 ----
    let restored = false;
    try {
      const raw = sessionStorage.getItem(SS_STATE);
      if (raw) {
        const s = JSON.parse(raw);
        if (typeof s.idx === 'number' && s.idx >= 0 && s.idx < tracks.length) {
          const interacted = sessionStorage.getItem(SS_INTERACTED) === '1';
          const shouldAutoplay = !!s.wasPlaying && interacted;
          loadTrack(s.idx, shouldAutoplay, s.time || 0);
          restored = true;
        }
      }
    } catch {}
    if (!restored) loadTrack(0, false);
  })();
</script>
