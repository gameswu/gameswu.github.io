---
/**
 * 主题切换按钮（暗/亮）
 * 在 <html data-theme="dark|light"> 上切换；localStorage 持久化
 * 初始化脚本（防 FOUC）由 BaseLayout 内联执行
 */
---

<button
  id="theme-toggle"
  type="button"
  class="btn btn-ghost w-9 h-9 p-0 rounded-full"
  aria-label="切换主题"
  title="切换明暗主题"
>
  <!-- 月亮（暗色主题显示，点击后切到亮色） -->
  <svg class="theme-icon theme-icon-moon w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
      d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
  </svg>
  <!-- 太阳（亮色主题显示） -->
  <svg class="theme-icon theme-icon-sun w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
    <circle cx="12" cy="12" r="4" stroke-width="2" />
    <path stroke-linecap="round" stroke-width="2"
      d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32l1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
  </svg>
</button>

<script>
  const btn = document.getElementById('theme-toggle');
  const root = document.documentElement;

  function currentTheme(): 'dark' | 'light' {
    return root.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
  }

  function applyTheme(t: 'dark' | 'light') {
    root.setAttribute('data-theme', t);
    try { localStorage.setItem('theme', t); } catch {}
  }

  btn?.addEventListener('click', () => {
    applyTheme(currentTheme() === 'dark' ? 'light' : 'dark');
  });
</script>

<style is:global>
  [data-theme='dark'] .theme-icon-sun,
  [data-theme='light'] .theme-icon-moon {
    display: none;
  }
</style>
