---
import ThirdEye from './ThirdEye.astro';
import { siteProfile } from '@/config/site';

const currentYear = new Date().getFullYear();
const { copyright, decoration, links } = siteProfile.footer;
const social = siteProfile.social;
---

<footer class="border-t mt-16" style="border-color: var(--border-subtle);">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2 text-sm" style="color: var(--text-muted);">
        <div class="opacity-70">
          <ThirdEye size="xs" animate={false} />
        </div>
        <span>&copy; {currentYear} {copyright}</span>
      </div>

      <div class="flex items-center gap-4 text-sm">
        {links.map((link, i) => (
          <>
            {i > 0 && <span style="color: var(--border-strong);">|</span>}
            <a
              href={link.href}
              class="footer-link transition-colors duration-200"
              style="color: var(--text-muted);"
            >{link.label}</a>
          </>
        ))}
        {social.map((s) => (
          <>
            <span style="color: var(--border-strong);">|</span>
            <a
              href={s.href}
              target={s.href.startsWith('http') ? '_blank' : undefined}
              rel={s.href.startsWith('http') ? 'noopener noreferrer' : undefined}
              class="footer-link transition-colors duration-200"
              style="color: var(--text-muted);"
              aria-label={s.label}
              title={s.label}
            >
              {s.icon === 'rss' && (
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z"/>
                </svg>
              )}
              {s.icon === 'github' && (
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                </svg>
              )}
            </a>
          </>
        ))}
      </div>
    </div>

    <div class="mt-6 flex justify-center">
      <div class="flex items-center gap-2 text-xs" style="color: var(--text-muted); opacity: 0.7;">
        <div class="w-12 h-px" style="background: linear-gradient(to right, transparent, var(--border-strong));"></div>
        <span>{decoration}</span>
        <div class="w-12 h-px" style="background: linear-gradient(to left, transparent, var(--border-strong));"></div>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-link:hover { color: var(--text-primary); }
</style>
