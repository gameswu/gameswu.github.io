---
/**
 * 站内搜索（Pagefind 驱动）
 *
 * - 构建时 pagefind 扫描 dist/ 下 data-pagefind-body 区域生成索引
 * - 运行时通过 Vite 忽略注释的动态 import() 加载 /pagefind/pagefind.js
 * - 开发模式下 /pagefind 不存在，会友好提示运行 build
 * - 支持 ⌘/Ctrl+K 打开、Esc 关闭、↑↓ 选择、↵ 打开
 */
---

<!-- 触发按钮 -->
<button
  id="search-trigger"
  type="button"
  class="btn btn-ghost !py-1.5 !px-3 text-sm"
  aria-label="搜索文章"
>
  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
      d="M21 21l-4.35-4.35M17 10a7 7 0 11-14 0 7 7 0 0114 0z" />
  </svg>
  <span class="hidden sm:inline">搜索</span>
  <kbd
    class="hidden md:inline-flex items-center gap-0.5 px-1.5 py-0.5 rounded text-[10px] font-mono"
    style="background: var(--subtle); color: var(--text-muted); border: 1px solid var(--border-subtle);"
  >
    <span class="text-sm leading-none">⌘</span>K
  </kbd>
</button>

<!-- 搜索对话框 -->
<div id="search-modal" class="fixed inset-0 z-[100] hidden" aria-hidden="true">
  <div
    id="search-backdrop"
    class="absolute inset-0 backdrop-blur-sm"
    style="background: color-mix(in srgb, var(--canvas) 75%, transparent);"
  ></div>

  <div class="relative max-w-2xl mx-auto mt-[10vh] px-4 sm:px-6">
    <div
      class="card overflow-hidden"
      style="box-shadow: 0 25px 60px -15px var(--glow-brand), 0 0 0 1px var(--border-strong);"
    >
      <!-- 输入框 -->
      <div class="relative" style="border-bottom: 1px solid var(--border-subtle);">
        <svg
          class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5"
          style="color: var(--text-muted);"
          fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M21 21l-4.35-4.35M17 10a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          id="search-input"
          type="search"
          placeholder="读取你心中的词语..."
          autocomplete="off"
          class="w-full bg-transparent pl-12 pr-16 py-4 focus:outline-none"
          style="color: var(--text-primary);"
        />
        <button
          id="search-close"
          class="absolute right-3 top-1/2 -translate-y-1/2 px-2 py-1 rounded text-xs font-mono transition-colors"
          style="color: var(--text-muted); border: 1px solid var(--border-subtle);"
          aria-label="关闭"
        >
          ESC
        </button>
      </div>

      <!-- 结果 -->
      <div id="search-results" class="max-h-[60vh] overflow-y-auto p-2">
        <div class="search-empty px-6 py-12 text-center text-sm" style="color: var(--text-muted);">
          开始输入以搜索文章…
        </div>
      </div>

      <!-- 脚注 -->
      <div
        class="px-4 py-2 text-xs flex items-center justify-between"
        style="border-top: 1px solid var(--border-subtle); color: var(--text-muted);"
      >
        <span>由 Pagefind 驱动</span>
        <span class="hidden sm:inline">
          <kbd class="px-1 font-mono">↑↓</kbd> 选择 ·
          <kbd class="px-1 font-mono">↵</kbd> 打开
        </span>
      </div>
    </div>
  </div>
</div>

<script>
  type PagefindResult = {
    id: string;
    data: () => Promise<{
      url: string;
      excerpt: string;
      meta: { title?: string; image?: string; date?: string; tags?: string };
    }>;
  };
  type Pagefind = {
    search: (q: string) => Promise<{ results: PagefindResult[] }>;
    init?: () => Promise<void>;
  };

  const trigger = document.getElementById('search-trigger');
  const modal = document.getElementById('search-modal');
  const backdrop = document.getElementById('search-backdrop');
  const closeBtn = document.getElementById('search-close');
  const input = document.getElementById('search-input') as HTMLInputElement | null;
  const resultsEl = document.getElementById('search-results');

  let pagefind: Pagefind | null = null;
  let loadingPromise: Promise<Pagefind | null> | null = null;
  let activeIndex = -1;

  async function loadPagefind(): Promise<Pagefind | null> {
    if (pagefind) return pagefind;
    if (loadingPromise) return loadingPromise;
    loadingPromise = (async () => {
      try {
        // 运行时拼出路径，使 Rollup 无法做静态解析；/pagefind 仅在 build 后存在
        const path = '/pagefind' + '/pagefind.js';
        const url = new URL(path, window.location.origin).href;
        const mod = await import(/* @vite-ignore */ url);
        if (mod.init) await mod.init();
        pagefind = mod as Pagefind;
        return pagefind;
      } catch (err) {
        console.warn('[Search] Pagefind 索引未找到，请先运行 npm run build', err);
        return null;
      }
    })();
    return loadingPromise;
  }

  function openModal() {
    if (!modal) return;
    modal.classList.remove('hidden');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    setTimeout(() => input?.focus(), 50);
    loadPagefind();
  }

  function closeModal() {
    if (!modal) return;
    modal.classList.add('hidden');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    if (input) input.value = '';
    activeIndex = -1;
    renderEmpty('开始输入以搜索文章…');
  }

  function renderEmpty(msg: string) {
    if (!resultsEl) return;
    resultsEl.innerHTML = `<div class="search-empty px-6 py-12 text-center text-sm" style="color: var(--text-muted);">${msg}</div>`;
  }

  function escapeHtml(s: string) {
    return s.replace(/[&<>"']/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!)
    );
  }

  function getItems(): HTMLAnchorElement[] {
    if (!resultsEl) return [];
    return Array.from(resultsEl.querySelectorAll<HTMLAnchorElement>('a[data-result-index]'));
  }

  function setActive(i: number) {
    const items = getItems();
    if (items.length === 0) return;
    const next = ((i % items.length) + items.length) % items.length;
    items.forEach((el, idx) => {
      if (idx === next) {
        el.classList.add('search-result-active');
        el.scrollIntoView({ block: 'nearest' });
      } else {
        el.classList.remove('search-result-active');
      }
    });
    activeIndex = next;
  }

  async function doSearch(q: string) {
    if (!resultsEl) return;
    activeIndex = -1;
    if (!q.trim()) {
      renderEmpty('开始输入以搜索文章…');
      return;
    }
    const pf = await loadPagefind();
    if (!pf) {
      renderEmpty('搜索索引尚未生成，请运行 <code>npm run build</code> 后再试。');
      return;
    }
    const { results } = await pf.search(q);
    if (results.length === 0) {
      renderEmpty('未读取到匹配的思绪…');
      return;
    }
    const datas = await Promise.all(results.slice(0, 10).map((r) => r.data()));
    resultsEl.innerHTML = datas
      .map(
        (d, i) => `
      <a href="${d.url}" data-result-index="${i}"
        class="search-result block px-4 py-3 rounded-lg transition-colors">
        <div class="flex items-start gap-3">
          ${d.meta.image
            ? `<img src="${escapeHtml(d.meta.image)}" alt=""
                 class="w-16 h-16 rounded-md object-cover flex-shrink-0"
                 style="border: 1px solid var(--border-subtle);" />`
            : ''}
          <div class="flex-1 min-w-0">
            <div class="text-sm font-serif font-semibold truncate" style="color: var(--text-primary);">
              ${escapeHtml(d.meta.title ?? '无标题')}
            </div>
            <div class="mt-1 text-xs line-clamp-2 leading-relaxed pagefind-excerpt" style="color: var(--text-secondary);">
              ${d.excerpt}
            </div>
            ${d.meta.date
              ? `<div class="mt-1 text-[10px]" style="color: var(--text-muted);">${escapeHtml(d.meta.date)}</div>`
              : ''}
          </div>
        </div>
      </a>
    `
      )
      .join('');
    setActive(0);
  }

  let timer: ReturnType<typeof setTimeout> | null = null;
  input?.addEventListener('input', () => {
    if (timer) clearTimeout(timer);
    timer = setTimeout(() => doSearch(input.value), 150);
  });

  trigger?.addEventListener('click', openModal);
  closeBtn?.addEventListener('click', closeModal);
  backdrop?.addEventListener('click', closeModal);

  // 键盘：全局快捷键
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      if (modal?.classList.contains('hidden')) openModal();
      else closeModal();
      return;
    }
    if (modal?.classList.contains('hidden')) return;
    if (e.key === 'Escape') {
      closeModal();
    } else if (e.key === 'ArrowDown') {
      e.preventDefault();
      setActive(activeIndex + 1);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      setActive(activeIndex - 1);
    } else if (e.key === 'Enter') {
      const items = getItems();
      const target = items[activeIndex];
      if (target) {
        e.preventDefault();
        window.location.href = target.href;
      }
    }
  });
</script>

<style is:global>
  .search-result:hover,
  .search-result.search-result-active {
    background: var(--accent-soft);
  }
  .pagefind-excerpt mark {
    background: color-mix(in srgb, var(--accent) 30%, transparent);
    color: var(--accent);
    padding: 0 2px;
    border-radius: 2px;
  }
</style>
